# Copy to .env and fill in your values
# These override config.toml settings via EVM_INDEXER__ prefix

EVM_INDEXER__RPC__HTTP_URL=https://mainnet.infura.io/v3/YOUR_API_KEY
EVM_INDEXER__RPC__WS_URL=wss://mainnet.infura.io/ws/v3/YOUR_API_KEY
EVM_INDEXER__DATABASE__URL=postgresql://postgres:password@localhost:5432/evm_indexer
EVM_INDEXER__INDEXER__START_BLOCK=0
EVM_INDEXER__INDEXER__CONCURRENT_BLOCKS=10
EVM_INDEXER__INDEXER__CONFIRMATIONS=12
